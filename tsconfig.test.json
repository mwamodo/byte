{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "types": ["node"],
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "rootDir": "."
    },
    "include": ["src/**/*.ts", "test/**/*.ts"]
}

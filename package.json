{
    "name": "byte",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "files": [
        "dist"
    ],
    "bin": {
        "byte": "./dist/cli.js"
    },
    "description": "Byte — AI desktop assistant built on pi-mono SDK packages.",
    "scripts": {
        "dev": "tsx src/cli.ts",
        "build": "tsc -p tsconfig.json",
        "prepare": "npm run build",
        "lint": "eslint . --max-warnings=0",
        "format": "prettier --write .",
        "start": "node dist/cli.js",
        "test": "node --import tsx --test test/**/*.test.ts"
    },
    "engines": {
        "node": ">=20.6.0"
    },
    "dependencies": {
        "@mariozechner/pi-ai": "^0.58.2",
        "@mariozechner/pi-coding-agent": "^0.58.2",
        "grammy": "^1.41.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.3.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "tsx": "^4.20.5",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.57.0"
    }
}

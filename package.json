{
    "name": "byte",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/app.js",
    "files": [
        "dist"
    ],
    "bin": {
        "byte": "./dist/cli.js"
    },
    "description": "Byte — AI desktop assistant built on pi-mono SDK packages.",
    "scripts": {
        "dev": "tsx src/cli.ts",
        "build": "npm run build:main && npm run build:renderer",
        "build:main": "tsc -p tsconfig.json",
        "build:renderer": "vite build --config vite.config.ts",
        "dist": "npm run build && electron-builder",
        "prepare": "npm run build",
        "lint": "eslint . --max-warnings=0",
        "format": "prettier --write .",
        "start": "node dist/cli.js",
        "dev:renderer": "vite --config vite.config.ts --host 127.0.0.1",
        "dev:electron": "wait-on tcp:5173 && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron dist/app.js",
        "dev:app": "npm run build:main && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
        "test": "node --import tsx --test test/**/*.test.ts"
    },
    "engines": {
        "node": ">=20.6.0"
    },
    "dependencies": {
        "@mariozechner/pi-ai": "^0.58.2",
        "@mariozechner/pi-coding-agent": "^0.58.2",
        "electron": "^37.2.6",
        "grammy": "^1.41.1"
    },
    "devDependencies": {
        "@types/react": "^19.1.12",
        "@types/react-dom": "^19.1.9",
        "@vitejs/plugin-react": "^5.0.2",
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.3.0",
        "concurrently": "^9.2.1",
        "electron-builder": "^26.0.12",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "tsx": "^4.20.5",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.57.0",
        "vite": "^7.1.5",
        "wait-on": "^8.0.5"
    }
}
